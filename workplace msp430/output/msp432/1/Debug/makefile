# Tool invocations
mpu6050.out: $(OBJS) $(CMD_SRCS) $(LIB_SRCS) $(A_SRCS) $(GEN_CMDS)
	@echo 'Building target: "$@"'
	@echo 'Invoking: ARM Linker'
	"D:/ccs/tools/compiler/ti-cgt-arm_20.2.1.LTS/bin/armcl" -mv7M4 --code_state=16 --float_support=FPv4SPD16 -me --advice:power=all --define=__MSP432P401R__ --define=MPU6050 --define=MOTION_DRIVER_TARGET_MSP432 --define=ccs -g --gcc --diag_warning=225 --diag_wrap=off --display_error_number --abi=eabi -z -m"mpu6050.map" --heap_size=1024 --stack_size=512 -i"D:/ccs/ccs_base/arm/include" -i"D:/ccs/tools/compiler/ti-cgt-arm_20.2.1.LTS/lib" -i"D:/ccs/tools/compiler/ti-cgt-arm_20.2.1.LTS/include" --reread_libs --diag_wrap=off --display_error_number --warn_sections --xml_link_info="mpu6050_linkInfo.xml" --rom_model -o "mpu6050.out" $(ORDERED_OBJS) $(A_SRCS)
	@echo 'Finished building target: "$@"'
	@echo ' '

mpu6050.hex: $(EXE_OUTPUTS)
	@echo 'Building files: $(strip $(EXE_OUTPUTS__QUOTED))'
	@echo 'Invoking: ARM Hex Utility'
	"D:/ccs/tools/compiler/ti-cgt-arm_20.2.1.LTS/bin/armhex" --memwidth=8 --romwidth=8 -o "mpu6050.hex" $(EXE_OUTPUTS__QUOTED)
